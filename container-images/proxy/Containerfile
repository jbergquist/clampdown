# Auth proxy — holds API keys, proxies requests to upstream APIs.
# FROM scratch: no shell, no package manager, no libc.
# CA certificates copied from Alpine for TLS to upstream APIs.
FROM alpine:3.23 AS certs
RUN true

FROM scratch
COPY --from=certs /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY sidecar/seal/sandbox-seal /usr/local/bin/sandbox-seal
COPY proxy/auth-proxy /usr/local/bin/auth-proxy
ENTRYPOINT ["/usr/local/bin/sandbox-seal", "--", "/usr/local/bin/auth-proxy"]
