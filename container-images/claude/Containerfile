# Install claude and podman-remote
FROM alpine:3.23 AS builder

# Pin claude-code version — update deliberately after testing.
ARG CLAUDE_VERSION=2.1.92
RUN apk add --no-cache bash curl nodejs podman-remote \
    && CLAUDE_CODE_VERSION="${CLAUDE_VERSION}" curl -fsSL https://claude.ai/install.sh | bash

# Network guidance helper — LD_PRELOAD .so for connect() firewall messages.
FROM alpine:3.23 AS sandbox-network-helper
RUN apk add --no-cache gcc musl-dev
COPY helpers/sandbox_network_helper.c /build/
RUN gcc -shared -fPIC -Os -s -o /sandbox_network_helper.so /build/sandbox_network_helper.c

# Docker Compose standalone binary.
# Pinned to v2.32.4 — last version confirmed working with podman compat API v1.41.
# docker compose v2.29+ may require API v1.44+; test before bumping.
FROM alpine:3.23 AS compose
ARG TARGETARCH
ARG COMPOSE_VERSION=v2.32.4
RUN wget -qO /docker-compose \
    "https://github.com/docker/compose/releases/download/${COMPOSE_VERSION}/docker-compose-linux-$(uname -m)" \
    && chmod +x /docker-compose

# Main agent image. Base alpine + nodejs (for claude) and some cli utils.
FROM alpine:3.23

COPY --from=builder /root/.local/share/claude/versions/* /usr/local/bin/claude
COPY sidecar/seal/sandbox-seal /usr/local/bin/sandbox-seal
COPY helpers/sandbox_command_helper.sh /etc/sandbox_command_helper.sh
COPY --from=sandbox-network-helper /sandbox_network_helper.so /usr/local/lib/sandbox_network_helper.so
# podman-remote is a self-contained Go binary (only links musl libc).
# Copy it directly to avoid pulling 40+ unnecessary runtime deps (crun, conmon,
# netavark, glib, gnupg, etc.) that Alpine's package drags in.
# Symlinked to both `podman` and `docker` for compatibility.
COPY --from=builder /usr/bin/podman-remote /usr/bin/podman-remote
# Docker Compose standalone binary — talks to sidecar podman API via DOCKER_HOST.
COPY --from=compose /docker-compose /usr/local/bin/docker-compose

# Busybox (built into Alpine) provides coreutils: ls, cp, mv, cat, head, etc.
# Only add packages not covered by busybox.
RUN apk add --no-cache \
    bash coreutils nodejs \
    ripgrep jq \
    && ln -s podman-remote /usr/bin/podman \
    && ln -s podman-remote /usr/bin/docker \
    && mkdir -p /usr/local/lib/docker/cli-plugins \
    && ln -s /usr/local/bin/docker-compose /usr/local/lib/docker/cli-plugins/docker-compose

ENV SHELL=/bin/bash
ENV BASH_ENV=/etc/sandbox_command_helper.sh
ENV LD_PRELOAD=/usr/local/lib/sandbox_network_helper.so

ENTRYPOINT ["/usr/local/bin/sandbox-seal", "--", "/usr/local/bin/claude"]
